# Example environment variables. Copy to .env and fill in real values.
# The agent itself does NOT auto-load .env — this file only documents which
# variables the process is expected to see.

# Bearer token used by clients (Companion, curl). Generate with e.g.
#   openssl rand -hex 32
DESK_AGENT_TOKEN=change-me

# Optional: name of the audio device SoundVolumeView should switch to
# for the TV-Gaming action. Matches the "Name" column in SoundVolumeView.
DESK_AGENT_AUDIO_TV=TV
DESK_AGENT_AUDIO_DESK=Headset

# Optional: override Windows Discord toggle-mute hotkey.
# Windows uses SendKeys syntax (^+m == Ctrl+Shift+M).
DESK_AGENT_DISCORD_HOTKEY=

# Optional: Discord RPC integration for stateful mute/deafen HTTP endpoints.
# Create a Discord application and set its OAuth redirect URI to http://localhost.
# Keep the client secret out of Git.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost
DISCORD_TOKEN_CACHE=
